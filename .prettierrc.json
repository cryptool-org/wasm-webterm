{
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": false,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "objectWrap": "collapse",
  "arrowParens": "always",
  "proseWrap": "always",
  "endOfLine": "lf",
  "embeddedLanguageFormatting": "off"
}
